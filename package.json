{
  "name": "sprouter_landing_next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint --fix \"./**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,css,scss,md,json}\" --config ./.prettierrc",
    "prepare": "husky install"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,css,scss,md}": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.21.0",
    "@emotion/react": "^11.14.0",
    "@zag-js/popper": "^1.15.5",
    "axios": "^1.9.0",
    "clsx": "^2.1.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-no-cyrillic-string": "^1.0.5",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lenis": "^1.3.17",
    "motion": "^12.12.1",
    "next": "^15.3.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5"
  }
}
